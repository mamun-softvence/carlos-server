enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BookingCreatedBy {
  STUDENT
  TUTOR
  ADMIN
}

enum LiveClassStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum TaskStatus {
  PENDING
  COMPLETE
}

enum SubscriptionStatus {
  PENDING
  INCOMPLETE
  ACTIVE
  PAST_DUE
  UNPAID
  PAUSED
  EXPIRED
  CANCELLED
  FAILED
}

model User {
  id                    String   @id @default(uuid())
  name                  String?
  email                 String   @unique
  phoneNumber           String?
  timeZone              String?
  googleCalendarEnabled Boolean  @default(false)
  googleCalendarEmail   String?
  googleCalendarAccessToken String?
  googleCalendarRefreshToken String?
  googleCalendarTokenExpiry DateTime?
  password              String?
  role                  UserRole @default(STUDENT)

  avatarPublicId String?
  avatarUrl      String?

  provider   AuthProvider @default(EMAIL)
  providerId String?      @unique

  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(ACTIVE)
  acceptedTerms   Boolean    @default(false)

  refreshToken String?

  stripeCustomerId String? @unique

  resetCode       String?
  resetCodeExpiry DateTime?
  resetVerified   Boolean   @default(false)

  studentBookings        Booking[]               @relation("StudentBookings")
  tutorBookings          Booking[]               @relation("TutorBookings")
  adminAssignedBookings  Booking[]               @relation("AdminAssignedBookings")
  bookingParticipations  BookingParticipant[]    @relation("StudentBookingParticipants")
  liveClassMessages      LiveClassMessage[]
  savedLiveClassMessages SavedLiveClassMessage[]
  googleCalendarBookingEvents GoogleCalendarBookingEvent[]

  studentSubscriptions StudentSubscription[]
  subscriptionPayments StudentSubscriptionPayment[]

  studentCreditBalance    StudentCreditBalance[]
  notifications           Notification[]                   @relation("UserNotifications")
  messageParticipations   MessageConversationParticipant[]
  sentDirectMessages      DirectMessage[]                  @relation("SentDirectMessages")
  competencyLogsAsStudent StudentLogCompetency[]           @relation("StudentCompetencyLogs")
  competencyLogsAsTutor   StudentLogCompetency[]           @relation("TutorCompetencyLogs")
  assignedTasksAsStudent  Task[]                           @relation("StudentTasks")
  assignedTasksAsTutor    Task[]                           @relation("TutorTasks")

  recurringSchedulesAsTutor   TutorRecurringSchedule[] @relation("TutorRecurringSchedules")
  recurringSchedulesAsStudent TutorRecurringSchedule[] @relation("StudentRecurringSchedules")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Booking {
  id                String           @id @default(uuid())
  studentId         String?          // Changed from String to String?
  tutorId           String?
  assignedByAdminId String?
  createdBy         BookingCreatedBy
  status            BookingStatus    @default(PENDING)

  topic String?
  note  String?
  tags  String[]                     // Added tags field

  tutorBookingType    TutorBookingType? // Added tutorBookingType
  recurringScheduleId String?           // Added recurringScheduleId

  requestedDate      DateTime?
  requestedTimeLabel String?

  scheduledAt     DateTime?
  durationMinutes Int?
  courseReference String?
  moduleReference String?
  liveClassStatus LiveClassStatus @default(SCHEDULED)
  startedAt       DateTime?
  endedAt         DateTime?

  cancelReason String?
  cancelledAt  DateTime?
  completedAt  DateTime?

  creditCost       Int       @default(0)
  creditDeductedAt DateTime?
  creditRefundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student                User?                   @relation("StudentBookings", fields: [studentId], references: [id], onDelete: SetNull) // Changed to User? and SetNull
  tutor                  User?                   @relation("TutorBookings", fields: [tutorId], references: [id], onDelete: SetNull)
  assignedByAdmin        User?                   @relation("AdminAssignedBookings", fields: [assignedByAdminId], references: [id], onDelete: SetNull)
  recurringSchedule      TutorRecurringSchedule? @relation(fields: [recurringScheduleId], references: [id], onDelete: SetNull) // Added recurringSchedule relation
  participants           BookingParticipant[]
  liveClassMessages      LiveClassMessage[]
  competencyLogs         StudentLogCompetency[]
  tasks                  Task[]
  savedLiveClassMessages SavedLiveClassMessage[]
  sharedSessionPdfs      SessionSharedPdf[]
  googleCalendarBookingEvents GoogleCalendarBookingEvent[]

  @@index([studentId])
  @@index([tutorId])
  @@index([assignedByAdminId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdBy])
  @@index([liveClassStatus])
  @@index([recurringScheduleId])
  @@map("bookings")
}

model BookingParticipant {
  id        String   @id @default(uuid())
  bookingId String
  studentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student User    @relation("StudentBookingParticipants", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([bookingId, studentId])
  @@index([bookingId])
  @@index([studentId])
  @@map("booking_participants")
}

model LiveClassMessage {
  id        String   @id @default(uuid())
  bookingId String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking               Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender                User                   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  savedLiveClassMessage SavedLiveClassMessage?

  @@index([bookingId, createdAt])
  @@index([senderId])
  @@map("live_class_messages")
}

model SavedLiveClassMessage {
  id        String   @id @default(uuid())
  bookingId String
  messageId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  message LiveClassMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User?            @relation(fields: [userId], references: [id])
  userId  String?

  @@index([bookingId, createdAt])
  @@map("saved_live_class_messages")
}

model SessionSharedPdf {
  id        String   @id @default(uuid())
  bookingId String
  title     String
  pdfUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@map("session_shared_pdfs")
}

model GoogleCalendarBookingEvent {
  id              String   @id @default(uuid())
  bookingId       String
  userId          String
  externalEventId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
  @@index([bookingId])
  @@index([userId])
  @@map("google_calendar_booking_events")
}

model MessageConversation {
  id             String   @id @default(uuid())
  participantKey String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participants MessageConversationParticipant[]
  messages     DirectMessage[]

  @@map("message_conversations")
}

model MessageConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("message_conversation_participants")
}

model DirectMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("SentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("direct_messages")
}

model Notification {
  id          String    @id @default(uuid())
  recipientId String
  type        String
  title       String
  message     String
  data        Json?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recipient User @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@index([type])
  @@map("notifications")
}

model BookingRule {
  id                 String   @id @default(uuid())
  minimumNoticeHours Int      @default(24)
  cancellationHours  Int      @default(12)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("booking_rules")
}

model Task {
  id        String     @id @default(uuid())
  studentId String
  tutorId   String
  bookingId String?
  title     String
  pdfUrl    String
  dueDate   DateTime
  status    TaskStatus @default(PENDING)

  answerPdfUrl String?
  submittedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User     @relation("StudentTasks", fields: [studentId], references: [id], onDelete: Cascade)
  tutor   User     @relation("TutorTasks", fields: [tutorId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([tutorId])
  @@index([bookingId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model StudentLogCompetency {
  id        String  @id @default(uuid())
  studentId String
  tutorId   String
  bookingId String?

  input        Int @default(0)
  output       Int @default(0)
  architecture Int @default(0)
  lexicon      Int @default(0)
  dynamics     Int @default(0)

  totalPoints        Int     @default(0)
  territoryExpansion Decimal @default(0) @db.Decimal(5, 2)
  feedback           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User     @relation("StudentCompetencyLogs", fields: [studentId], references: [id], onDelete: Cascade)
  tutor   User     @relation("TutorCompetencyLogs", fields: [tutorId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([studentId, tutorId])
  @@index([studentId])
  @@index([tutorId])
  @@index([bookingId])
  @@map("student_log_competencies")
}

model SubscriptionPlan {
  id              String  @id @default(uuid())
  name            String
  price           Decimal @db.Decimal(10, 2)
  durationDays    Int     @default(30)
  creditsPerMonth Int     @default(0)
  features        Json
  isActive        Boolean @default(true)

  stripeProductId String? @unique
  stripePriceId   String? @unique
  currency        String  @default("usd")
  billingInterval String  @default("month")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentSubscriptions StudentSubscription[]
  subscriptionPayments StudentSubscriptionPayment[]

  @@map("subscription_plans")
}

model StudentSubscription {
  id        String             @id @default(uuid())
  studentId String
  planId    String
  status    SubscriptionStatus @default(PENDING)

  startDate DateTime?
  endDate   DateTime?

  autoRenew Boolean @default(false)

  stripeCheckoutSessionId String?   @unique
  stripeSubscriptionId    String?   @unique
  stripeStatus            String?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  canceledAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  User                         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  payments StudentSubscriptionPayment[]

  @@index([studentId])
  @@index([planId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@map("student_subscriptions")
}

model StudentSubscriptionPayment {
  id                    String  @id @default(uuid())
  studentId             String
  studentSubscriptionId String?
  planId                String?

  stripeInvoiceId         String?   @unique
  stripeCheckoutSessionId String?
  amountPaid              Int
  currency                String
  status                  String
  paidAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student      User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subscription StudentSubscription? @relation(fields: [studentSubscriptionId], references: [id], onDelete: SetNull)
  plan         SubscriptionPlan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([studentSubscriptionId])
  @@index([planId])
  @@map("student_subscription_payments")
}

model StripeWebhookEvent {
  id            String    @id @default(uuid())
  stripeEventId String    @unique
  type          String
  payload       Json?
  processedAt   DateTime?
  error         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stripe_webhook_events")
}

model StudentCreditBalance {
  id           String @id @default(uuid())
  studentId    String @unique
  totalCredits Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_credit_balances")
}

enum TutorBookingType {
  CASUAL
  RECURRING
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model TutorRecurringSchedule {
  id                 String             @id @default(uuid())
  tutorId            String
  studentId          String?
  title              String?
  description        String?
  tags               String[]

  frequency          RecurringFrequency @default(WEEKLY)
  dayOfWeek          Int?
  dayOfMonth         Int?
  timeOfDay          String
  durationMinutes    Int                @default(50)

  openingWindowDays  Int                @default(7)
  isActive           Boolean            @default(true)
  lastGeneratedUpTo  DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tutor              User               @relation("TutorRecurringSchedules", fields: [tutorId], references: [id], onDelete: Cascade)
  student            User?              @relation("StudentRecurringSchedules", fields: [studentId], references: [id], onDelete: SetNull)
  bookings           Booking[]

  @@index([tutorId])
  @@index([isActive])
  @@map("tutor_recurring_schedules")
}
